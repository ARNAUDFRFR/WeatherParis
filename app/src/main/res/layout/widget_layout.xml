<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <!-- Accent indicator -->
        <ImageView
            android:id="@+id/accent_line"
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@color/accent_blue" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/accent_line"
            android:layout_alignParentStart="true"
            android:layout_marginTop="4dp"
            android:text="Météo Paris"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_last_update"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBaseline="@id/text_title"
            android:layout_toStartOf="@id/btn_refresh"
            android:layout_marginEnd="8dp"
            android:text="Actualisé : --:--"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/btn_refresh"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="11dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Refresh"
            android:src="@android:drawable/ic_menu_rotate" />

    </RelativeLayout>

    <!-- Current Conditions Block -->
    <LinearLayout
        android:id="@+id/layout_current_weather"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/icon_weather"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="Current weather icon"
            android:src="@android:drawable/ic_menu_report_image" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_current_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--.-°"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chargement..."
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_wind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- km/h"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/text_ecart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Écart saison : --"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 4-Part Daily Details Section (Matin, Midi, Soir, Nuit) -->
    <LinearLayout
        android:id="@+id/layout_temp_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_inner_background"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_marginBottom="10dp">

        <!-- Matin -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Matin"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />

            <ImageView
                android:id="@+id/icon_matin"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:contentDescription="Matin icon"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/text_matin_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Après-midi -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Midi"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />

            <ImageView
                android:id="@+id/icon_midi"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:contentDescription="Midi icon"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/text_midi_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Soir -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Soir"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />

            <ImageView
                android:id="@+id/icon_soir"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:contentDescription="Soir icon"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/text_soir_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nuit -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nuit"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />

            <ImageView
                android:id="@+id/icon_nuit"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:contentDescription="Nuit icon"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/text_nuit_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Forecast Section (6 Days, 2 Rows of 3 Columns) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp">

        <!-- Forecast Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <!-- Day 1 -->
            <RelativeLayout
                android:id="@+id/layout_day1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day1_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day1_morning"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="1dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day1_afternoon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day1_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="9sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day1"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Divider -->
            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_glass" />

            <!-- Day 2 -->
            <RelativeLayout
                android:id="@+id/layout_day2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day2_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day2_morning"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="1dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day2_afternoon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day2_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="9sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day2"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Divider -->
            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_glass" />

            <!-- Day 3 -->
            <RelativeLayout
                android:id="@+id/layout_day3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day3_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day3_morning"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="1dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day3_afternoon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day3_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="9sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day3"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

        </LinearLayout>

        <!-- Divider between rows -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_glass"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp" />

        <!-- Forecast Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Day 4 -->
            <RelativeLayout
                android:id="@+id/layout_day4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day4_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day4_morning"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="1dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day4_afternoon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day4_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="9sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day4"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Divider -->
            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_glass" />

            <!-- Day 5 -->
            <RelativeLayout
                android:id="@+id/layout_day5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day5_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day5_morning"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="1dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day5_afternoon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day5_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="9sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day5"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Divider -->
            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_glass" />

            <!-- Day 6 -->
            <RelativeLayout
                android:id="@+id/layout_day6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day6_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day6_morning"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="1dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day6_afternoon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day6_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="9sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day6"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Dynamic Comment Box (At the bottom, interactive) -->
    <LinearLayout
        android:id="@+id/layout_comment_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_inner_background"
        android:orientation="vertical"
        android:padding="6dp">

        <TextView
            android:id="@+id/text_comment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chargement des données..."
            android:textColor="@color/text_secondary"
            android:textSize="9.5sp"
            android:maxLines="3"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
