<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/widget_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_background" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

    <!-- Current Conditions Block -->
    <LinearLayout
        android:id="@+id/layout_current_weather"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/icon_weather"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="Current weather icon"
            android:src="@android:drawable/ic_menu_report_image" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_current_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--.-°"
                android:textColor="@color/text_primary"
                android:textSize="38sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />



        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <ImageView
                android:id="@+id/btn_refresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Refresh"
                android:src="@android:drawable/ic_menu_rotate"
                android:layout_marginEnd="-6dp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <!-- Precipitation Block -->
                <LinearLayout
                    android:id="@+id/layout_precip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/text_precip_proba"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pluie : --%"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_precip_volume"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Volume : -- mm"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Wind/Ecart Block -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/text_wind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- km/h"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_ecart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Écart saison : --"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- 4-Part Daily Details Section (Matin, Midi, Soir, Nuit) -->
    <LinearLayout
        android:id="@+id/layout_temp_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_inner_background"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_marginBottom="10dp">

        <!-- Matin -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Matin"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/icon_matin"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:contentDescription="Matin icon"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/text_matin_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Après-midi -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Midi"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/icon_midi"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:contentDescription="Midi icon"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/text_midi_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Soir -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Soir"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/icon_soir"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:contentDescription="Soir icon"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/text_soir_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nuit -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nuit"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/icon_nuit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:contentDescription="Nuit icon"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/text_nuit_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Dynamic Comment Box (Interactive, moved here) -->
    <LinearLayout
        android:id="@+id/layout_comment_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_inner_background"
        android:orientation="vertical"
        android:padding="6dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/text_comment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chargement des données..."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="4"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Forecast Section (6 Days, 2 Rows of 3 Columns) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="4dp">

        <!-- Forecast Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <!-- Day 1 -->
            <RelativeLayout
                android:id="@+id/layout_day1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day1_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day1_morning"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="12dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day1_afternoon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day1_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="6dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Divider -->
            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_glass" />

            <!-- Day 2 -->
            <RelativeLayout
                android:id="@+id/layout_day2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day2_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day2_morning"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="12dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day2_afternoon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day2_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="6dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Divider -->
            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_glass" />

            <!-- Day 3 -->
            <RelativeLayout
                android:id="@+id/layout_day3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day3_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day3_morning"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="12dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day3_afternoon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day3_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day3"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="6dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

        </LinearLayout>

        <!-- Divider between rows -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_glass"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="4dp" />

        <!-- Forecast Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Day 4 -->
            <RelativeLayout
                android:id="@+id/layout_day4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day4_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day4_morning"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="12dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day4_afternoon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day4_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day4"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="6dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Divider -->
            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_glass" />

            <!-- Day 5 -->
            <RelativeLayout
                android:id="@+id/layout_day5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day5_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day5_morning"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="12dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day5_afternoon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day5_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day5"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="6dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Divider -->
            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border_glass" />

            <!-- Day 6 -->
            <RelativeLayout
                android:id="@+id/layout_day6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/text_day6_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/icon_day6_morning"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="12dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                        <ImageView
                            android:id="@+id/icon_day6_afternoon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_report_image" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_day6_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--° / --°"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/dot_uncertain_day6"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="6dp"
                    android:src="@drawable/uncertain_dot"
                    android:visibility="gone" />
            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Last Update Section (Bottom Right) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/text_last_update"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Actualisé : --:--"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

    </RelativeLayout>

    </LinearLayout>

    <!-- Overlay for Rain/Precipitation Tracking -->
    <FrameLayout
        android:id="@+id/layout_rain_popup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EA121824"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Header with Title and Close Button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suivi des Précipitations (24h)"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true" />

                <ImageView
                    android:id="@+id/btn_close_rain_popup"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:contentDescription="Close"
                    android:clickable="true"
                    android:focusable="true" />

            </RelativeLayout>

            <!-- Graph Image -->
            <ImageView
                android:id="@+id/image_rain_graph"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_gallery" />

        </LinearLayout>

    </FrameLayout>

    <!-- Overlay for Temperature Tracking -->
    <FrameLayout
        android:id="@+id/layout_temp_popup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EA121824"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Header with Title and Close Button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suivi des Températures (24h)"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true" />

                <ImageView
                    android:id="@+id/btn_close_temp_popup"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:contentDescription="Close"
                    android:clickable="true"
                    android:focusable="true" />

            </RelativeLayout>

            <!-- Graph Image -->
            <ImageView
                android:id="@+id/image_temp_graph"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_gallery" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
